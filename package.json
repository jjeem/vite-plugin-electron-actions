{
  "name": "vite-plugin-electron-actions",
  "version": "0.0.1-alpha.1",
  "keywords": [
    "electron",
    "electron-actions",
    "vite",
    "vite-plugin"
  ],
  "license": "MIT",
  "author": "jjeem",
  "homepage": "https://github.com/jjeem/vite-plugin-electron-actions",
  "repository": "github:jjeem/vite-plugin-electron-actions",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./preload": {
      "import": {
        "types": "./dist/preload/index.d.mts",
        "default": "./dist/preload/index.mjs"
      },
      "require": {
        "types": "./dist/preload/index.d.cts",
        "default": "./dist/preload/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "biome check",
    "check:fix": "biome check --write"
  },
  "peerDependencies": {
    "electron": ">=30.0.0",
    "vite": ">=6.0.0"
  },
  "dependencies": {
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.125.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.3",
    "@types/node": "^24.10.0",
    "electron": "^30.0.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
